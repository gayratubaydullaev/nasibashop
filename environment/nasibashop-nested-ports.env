# Согласованный набор внешних (хост) портов, отличных от «классических».
# Подключение: из корня репозитория
#   cat environment/nasibashop-nested-ports.env >> .env
# либо скопируйте строки вручную в .env
#
# После изменения портов: `docker compose ... down` и `up` заново, обновите
# NEXT_PUBLIC_API_URL во frontends, nginx proxy_pass к Kong, при необходимости Kafka — клиентов с хоста.
#
# Kong API:  http://127.0.0.1:18000   (Admin: 18001)
# Postgres:  127.0.0.1:15432
# Redis:     127.0.0.1:16379
# Kafka ext: 127.0.0.1:19094

NASIBASHOP_POSTGRES_PORT=15432
NASIBASHOP_REDIS_PORT=16379
NASIBASHOP_KAFKA_PORT_9092=19092
NASIBASHOP_KAFKA_PORT_9094=19094
NASIBASHOP_MEILISEARCH_PORT=17700
NASIBASHOP_MONGO_PORT=37017
NASIBASHOP_CONSUL_HTTP_PORT=18500
NASIBASHOP_CONSUL_DNS_UDP_PORT=18600
NASIBASHOP_KONG_PROXY_PORT=18000
NASIBASHOP_KONG_ADMIN_PORT=18001
