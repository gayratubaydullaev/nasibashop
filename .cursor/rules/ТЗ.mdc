│ ├── order-service/ # Java (Spring Boot) или Kotlin
│ ├── payment-service/ # Node.js (Nest.js) — для гибкой интеграции с Payme/Click
│ ├── delivery-service/ # Go (Golang)
│ ├── search-service/ # Rust (Actix-web) — максимальная производительность
│ ├── notification-service/ # Node.js (Nest.js) — WebSockets + Firebase
